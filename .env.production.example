# Production wiring - copy these into the Vercel project's environment
# variables (or a .env.production) with the real origins.

# This site's own canonical origin - metadata, sitemap, JSON-LD.
NEXT_PUBLIC_SITE_URL=https://tripwheel.app

# better-auth backend the login form authenticates against.
NEXT_PUBLIC_API_URL=https://api.tripwheel.app

# Operator dashboard - a successful login redirects here.
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.tripwheel.app

# What lives at '/': 'landing' (default) or 'login' (login replaces homepage).
# Build-time flag - changing it on Vercel requires a redeploy.
NEXT_PUBLIC_HOMEPAGE=landing
